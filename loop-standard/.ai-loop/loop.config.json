    ".ai-loop/skills/skill-artifact-map.md",
    ".ai-loop/skills/skill-source-map.md"
  ],
  "evolution_file": ".ai-loop/evolution/project-loop-evolution.md",
  "worker_profiles": {
    "kimi-code": {
      "profile_file": "loop-standard/worker-profiles/kimi-code.json",
      "external_service": true,
      "default_state_root": ".ai-loop/runtime/kimi-code",
      "yolo_requires_separate_confirmation": false,
      "external_service_requires_confirmation": true,
      "sensitive_prompt_requires_confirmation": true,
      "memory_upgrade_requires_confirmation": true
    }
  },
  "skill_profiles": {
    "research-core": [
      "research-task-tree",
      "invariant-contract",
      "deterministic-verification",
      "skill-compliance-audit"
    ],
    "physics-sim": [
      "research-task-tree",
      "invariant-contract",
      "bounded-experiment-loop",
      "deterministic-verification",
      "independent-crosscheck",
      "result-provenance-audit",
      "skill-compliance-audit"
    ],
    "manuscript": [
      "research-task-tree",
      "deterministic-verification",
      "result-provenance-audit",
      "manuscript-consistency-audit",
      "skill-compliance-audit"
    ],
    "full-research": [
      "research-task-tree",
      "invariant-contract",
      "bounded-experiment-loop",
      "deterministic-verification",
      "independent-crosscheck",
      "result-provenance-audit",
      "manuscript-consistency-audit",
      "skill-compliance-audit"
    ]
  },
  "audit_required_inputs": [
    "status.json",
    "prompt.md",
    "report.md",
    "diff.patch",
    "verify.log",
    "status.txt",
    "relevant_source_files"
  ],
  "decisions": [
    "ACCEPTED",
    "REWORK",
    "BLOCKED"
  ],
  "rules": {
    "chat_history_is_not_source_of_truth": true,
    "worker_can_only_execute_current_phase": true,
    "supervisor_must_inspect_diff_verify_status_and_source": true,
    "missing_evidence_blocks_progress": true,
    "required_skill_artifacts_block_progress": true,
    "force_accept_requires_override_reason": true
  }
}
