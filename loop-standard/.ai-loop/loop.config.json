{
  "schema_version": "1.2",
  "loop_name": "supervisor-worker-loop",
  "supervisor": "Codex",
  "worker": "Worker Agent",
  "phase_evidence_required": [
    "prompt.md",
    "report.md",
    "diff.patch",
    "verify.log",
    "status.txt",
    "changed_business_files.txt",
    "changed_evidence_files.txt",
    "phase_requirements.json"
  ],
  "evidence_ledgers": [
    ".ai-loop/evidence/evidence-ledger.md",
    ".ai-loop/evidence/artifact-manifest.json",
    ".ai-loop/evidence/artifact-index.md",
    ".ai-loop/evidence/command-log.md",
